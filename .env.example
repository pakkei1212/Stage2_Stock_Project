# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this to .env and edit values. docker-compose reads .env automatically.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Jupyter ──────────────────────────────────────────────────────────────────

# Port Jupyter listens on (host side). Change if 8888 is taken on your machine.
JUPYTER_PORT=8888

# Optional Jupyter token for auth. Leave blank to disable (fine for local use).
# If set, open http://localhost:8888/?token=<your_token>
JUPYTER_TOKEN=

# ── Scheduled runner (interactive notebook) ────────────────────────────────────

# Cron schedule for the notebook runner service.
# Default: Mon–Fri at 18:00 (6pm local time inside the container, which uses UTC).
# To run daily at 09:30 UTC: SCHEDULE=30 9 * * *
# To run every Friday at 20:00 UTC: SCHEDULE=0 20 * * 5
SCHEDULE=0 18 * * 1-5

# Name of the notebook file (inside ./notebooks/) to run headlessly.
NOTEBOOK_NAME=nasdaq_stage2_screener.ipynb

# ── Weekly native-Python pipeline (pipeline/run_pipeline.py) ───────────────────

# Cron schedule for the weekly screen + VCP analysis pipeline.
# Default: Fridays at 21:00 UTC, after US market close.
PIPELINE_SCHEDULE=0 21 * * 5

# Required for Stage G (VCP vision analysis) — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Claude model used for VCP chart analysis. Defaults to claude-opus-4-8 if unset.
ANTHROPIC_MODEL=claude-opus-4-8

# How many top-ranked candidates get the (paid) vision VCP analysis each run.
VCP_TOP_N=20

# ── Logging ──────────────────────────────────────────────────────────────────

# Pipeline log verbosity: DEBUG, INFO (default), WARNING, or ERROR.
# DEBUG adds per-ticker drop reasons (e.g. why a symbol failed a filter).
# Applies to pipeline/run_pipeline.py only (see pipeline/logging_config.py).
LOG_LEVEL=INFO
