# ── .env.example ─────────────────────────────────────────────────────────────
# Copy this to .env and edit values. docker-compose reads .env automatically.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Jupyter ──────────────────────────────────────────────────────────────────

# Port Jupyter listens on (host side). Change if 8888 is taken on your machine.
JUPYTER_PORT=8888

# Optional Jupyter token for auth. Leave blank to disable (fine for local use).
# If set, open http://localhost:8888/?token=<your_token>
JUPYTER_TOKEN=

# ── Scheduled runner ──────────────────────────────────────────────────────────

# Cron schedule for the runner service.
# Default: Mon–Fri at 18:00 (6pm local time inside the container, which uses UTC).
# To run daily at 09:30 UTC: SCHEDULE=30 9 * * *
# To run every Friday at 20:00 UTC: SCHEDULE=0 20 * * 5
SCHEDULE=0 18 * * 1-5

# Name of the notebook file (inside ./notebooks/) to run headlessly.
NOTEBOOK_NAME=nasdaq_stage2_screener.ipynb
